<https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/agente_causale> a adms:Asset,
        dcatapit:Dataset,
        skos:ConceptScheme ;
    rdfs:label "This is the controlled vocabulary of causal agents adopted by INAIL classification"@en,
        "Vocabolario Controllato sulla classificazione degli agenti causali adottata dall'INAIL"@it ;
    skos:prefLabel "Vocabolario Controllato sulla classificazione degli agenti causali adottata dall'INAIL"@it ;
    rdfs:comment "Decodifica dell'agente, lavorazione, o esposizione che puo' essere causa o concausa di malattia"@it,
        "Decoding of the agent, processing, or aspect that can cause or contribute to disease"@en ;
    owl:versionInfo "0.5" ;
    rdfs:isDefinedBy <https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/agente_causale> ;
    adms:representationTechnique <http://purl.org/adms/representationtechnique/SKOS> ;
    dcat:contactPoint <https://w3id.org/italia/work-accident/data/organization/ufficioV> ;
    dcat:distribution <https://w3id.org/italia/work-accident/data/adm_serv/distribution/AC_CSV>,
        <https://w3id.org/italia/work-accident/data/adm_serv/distribution/AC_JSON>,
        <https://w3id.org/italia/work-accident/data/adm_serv/distribution/AC_RDF_TURTLE> ;
    dcat:keyword "agente causale"@it,
        "chemical product"@en,
        "inail"@it,
        "infortunio"@it,
        "malattia professionale"@it,
        "occupational accident"@en,
        "occupational disease"@en,
        "prodotto chimico"@it ;
    dcat:theme <http://publications.europa.eu/resource/authority/data-theme/ECON>,
        <http://publications.europa.eu/resource/authority/data-theme/HEAL>,
        <http://publications.europa.eu/resource/authority/data-theme/SOCI> ;
    dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/IRREG> ;
    dct:conformsTo <https://w3id.org/italia/data/standard/SKOS> ;
    dct:creator <https://w3id.org/italia/work-accident/data/organization/inail> ;
    dct:description "Decodifica dell'agente, lavorazione, o esposizione che puo' essere causa o concausa di malattia"@it,
        "Decoding of the agent, processing, or aspect that can cause or contribute to disease"@en ;
    dct:identifier "https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/agente_causale" ;
    dct:issued "2022-09-06"^^xsd:date ;
    dct:language <http://publications.europa.eu/resource/authority/language/ITA> ;
    dct:modified "2023-07-31"^^xsd:date ;
    dct:publisher <https://w3id.org/italia/work-accident/data/organization/inail> ;
    dct:relation <https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/agente_materiale>,
        <https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/deviazione>,
        <https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/tipo_contatto> ;
    dct:rightsHolder <https://w3id.org/italia/work-accident/data/organization/inail> ;
    dct:subject <http://eurovoc.europa.eu/1754>,
        <http://eurovoc.europa.eu/1761>,
        <http://eurovoc.europa.eu/1993>,
        <http://eurovoc.europa.eu/2739>,
        <http://eurovoc.europa.eu/100215> ;
    dct:title "Classification of causal agents adopted by INAIL Controlled Vocabulary"@en,
        "Vocabolario Controllato sulla classificazione degli agenti causali adottata dall'INAIL"@it ;
    dct:type <http://purl.org/adms/assettype/CodeList> ;
    ndc:keyConcept "agente_causale" ;
    skos:hasTopConcept ggroupagentcaus:1,
        ggroupagentcaus:2,
        ggroupagentcaus:3,
        ggroupagentcaus:4,
        ggroupagentcaus:5,
        ggroupagentcaus:6,
        ggroupagentcaus:7 ;
    xkos:numberOfLevels "3" .

